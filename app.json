{
  "expo": {
    "name": "JaKomo",
    "slug": "jakomo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7B2D8E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alghaf.jakomo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              },
              {
                "name": "RecaptchaInterop",
                "modular_headers": true
              }
            ]
          }
        }
      ],
      "expo-audio",
      [
        "react-native-audio-api",
        {
          "iosMicrophonePermission": "JaKomo uses your microphone so you can practice speaking Spanish out loud.",
          "androidPermissions": [
            "android.permission.RECORD_AUDIO",
            "android.permission.MODIFY_AUDIO_SETTINGS"
          ]
        }
      ],
      "expo-asset",
      "@react-native-community/datetimepicker",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.291396605020-tst5af47nind6ne3neqibonfjmvja4fq"
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D85A30"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a66517ea-05b8-4f49-ae8e-d1a920a5bbc7"
      }
    }
  }
}
